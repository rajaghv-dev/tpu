{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "MXU utilisation heatmap from Cloud Monitoring (tpu.googleapis.com/tpu/mxu_utilization). Filter by TPU instance with $tpu_name. Memory bandwidth and memory utilisation panels included alongside.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "stackdriver", "uid": "${DS_GCM}"},
      "description": "MXU utilisation over time, bucketed as a heatmap.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Spectral",
          "steps": 64
        },
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "filterValues": {"le": 1e-9},
        "legend": {"show": true},
        "rowsFrame": {"layout": "auto"},
        "tooltip": {"show": true, "yHistogram": false},
        "yAxis": {"axisPlacement": "left", "reverse": false, "unit": "percentunit"}
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "stackdriver", "uid": "${DS_GCM}"},
          "queryType": "metrics",
          "metricQuery": {
            "metricType": "tpu.googleapis.com/tpu/mxu_utilization",
            "filters": ["resource.label.node_id", "=~", "$tpu_name"],
            "groupBys": ["resource.label.node_id"],
            "aliasBy": "{{resource.label.node_id}}",
            "alignmentPeriod": "cloud-monitoring-auto",
            "perSeriesAligner": "ALIGN_MEAN",
            "crossSeriesReducer": "REDUCE_MEAN",
            "editorMode": "visual"
          },
          "refId": "A"
        }
      ],
      "title": "MXU Utilisation Heatmap (TPU $tpu_name)",
      "type": "heatmap"
    },
    {
      "datasource": {"type": "stackdriver", "uid": "${DS_GCM}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.6},
              {"color": "red", "value": 0.85}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 2,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "stackdriver", "uid": "${DS_GCM}"},
          "queryType": "metrics",
          "metricQuery": {
            "metricType": "tpu.googleapis.com/tpu/memory_bandwidth_utilization",
            "filters": ["resource.label.node_id", "=~", "$tpu_name"],
            "groupBys": ["resource.label.node_id"],
            "aliasBy": "{{resource.label.node_id}}",
            "alignmentPeriod": "cloud-monitoring-auto",
            "perSeriesAligner": "ALIGN_MEAN",
            "crossSeriesReducer": "REDUCE_MEAN"
          },
          "refId": "A"
        }
      ],
      "title": "Memory Bandwidth Utilisation",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "stackdriver", "uid": "${DS_GCM}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 3,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "stackdriver", "uid": "${DS_GCM}"},
          "queryType": "metrics",
          "metricQuery": {
            "metricType": "tpu.googleapis.com/tpu/memory_utilization",
            "filters": ["resource.label.node_id", "=~", "$tpu_name"],
            "groupBys": ["resource.label.node_id"],
            "aliasBy": "{{resource.label.node_id}}",
            "alignmentPeriod": "cloud-monitoring-auto",
            "perSeriesAligner": "ALIGN_MEAN",
            "crossSeriesReducer": "REDUCE_MEAN"
          },
          "refId": "A"
        }
      ],
      "title": "Memory Utilisation",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["tpu-bench", "cloud-monitoring", "mxu"],
  "templating": {
    "list": [
      {
        "name": "DS_GCM",
        "type": "datasource",
        "query": "stackdriver",
        "current": {"selected": false, "text": "Google Cloud Monitoring", "value": "Google Cloud Monitoring"},
        "hide": 0,
        "label": "Google Cloud Monitoring",
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "tpu_name",
        "type": "textbox",
        "current": {"selected": true, "text": ".*", "value": ".*"},
        "hide": 0,
        "label": "TPU node id (regex)",
        "query": ".*"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "TPU Bench - MXU Heatmap",
