{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Failure category breakdown (pie of benchmark.errors_total by error_category) plus recent FAILED log lines from Loki.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Pie of benchmark.errors_total bucketed by error_category.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}},
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 12, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"]},
        "pieType": "pie",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (error_category) (benchmark_errors_total)",
          "legendFormat": "{{error_category}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Failures by error_category",
      "type": "piechart"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Failure rate per phase (errors per second).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "errors / sec",
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 12, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (phase) (rate(benchmark_errors_total[5m]))",
          "legendFormat": "{{phase}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Error rate by phase",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "description": "Recent FAILED log entries from the benchmark logger (Loki).",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 12},
      "id": 3,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "editorMode": "code",
          "expr": "{service_name=\"tpu-bench\"} |= \"FAILED\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent FAILED log lines",
      "type": "logs"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["tpu-bench", "failures"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {"selected": false, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0,
        "label": "Prometheus / Mimir",
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": {"selected": false, "text": "Loki", "value": "Loki"},
        "hide": 0,
        "label": "Loki",
        "refresh": 1,
        "regex": ""
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "TPU Bench - Failures",
  "uid": "tpu-bench-failures",
  "version": 1,
  "weekStart": ""
}
