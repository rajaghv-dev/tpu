# ── GCP Configuration ──────────────────────────────────────────────────────────
# GCP project ID (required for GCP scripts)
GCP_PROJECT=my-gcp-project

# TPU VM name and zone (used by provision/teardown scripts)
TPU_NAME=tpu-bench-v5e
TPU_ZONE=us-east5-a

# GCS bucket for model and wheel caches (optional — skips caching if unset)
GCS_BUCKET=my-tpu-cache-bucket

# ── HuggingFace ─────────────────────────────────────────────────────────────────
# Required for gated models: Gemma, LLaMA, PaliGemma, CodeGemma, RecurrentGemma
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── JAX / XLA ───────────────────────────────────────────────────────────────────
# Override JAX device backend (useful for local CPU testing)
# Values: cpu | tpu | gpu | cuda | rocm
JAX_PLATFORMS=cpu

# XLA compilation cache directory (optional — speeds up repeated runs)
# XLA_FLAGS=--xla_gpu_cache_dir=/tmp/xla_cache

# ── Observability ────────────────────────────────────────────────────────────────
# OpenTelemetry export mode: off | otlp | file
# off  = no OTel export (default)
# otlp = gRPC export to TPU_BENCH_OTEL_ENDPOINT
# file = write OTLP-JSON to TPU_BENCH_OTEL_DIR (then replay via otel_view.sh)
TPU_BENCH_OTEL=off

# OTLP gRPC endpoint (otlp mode only)
TPU_BENCH_OTEL_ENDPOINT=http://localhost:4317

# OTLP-JSON output directory (file mode only)
TPU_BENCH_OTEL_DIR=results/otel/

# OpenTelemetry service name (appears in Grafana dashboards)
OTEL_SERVICE_NAME=tpu-bench

# ── GCS Cache URLs ────────────────────────────────────────────────────────────────
# Set after running: make cache-wheels-build / cache-models-upload / cache-xla-upload
# Leave blank to skip caching (fresh install each TPU provision)
WHEEL_CACHE_URL=
HF_MODEL_CACHE_URL=
XLA_COMPILE_CACHE_URL=

# ── Cost monitoring ───────────────────────────────────────────────────────────────
# BigQuery export table for month-to-date spend (optional — scripts/90_status.sh)
# Format: project.dataset.table
BILLING_BQ_TABLE=

# Budget alert threshold in USD (scripts/11_setup_budget.sh)
SESSION_BUDGET_USD=5.00
