    {
      "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
      "description": "Headline TPU number: fraction of time the TensorCore is processing. Sourced from GCP Cloud Monitoring metric tpu.googleapis.com/tpu/duty_cycle.",
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"showLegend": true}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
          "expr": "stackdriver_tpu_worker_tpu_googleapis_com_tpu_duty_cycle{project_id=~\"$project_id\",node_id=~\"$tpu_name\",zone=~\"$zone\"} * 100",
          "legendFormat": "duty_cycle {{node_id}}/{{tpu_worker_id}}",
          "refId": "A"
        }
      ],
      "title": "TPU Duty Cycle (%)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
      "description": "HBM bytes used per chip (tpu.googleapis.com/tpu/memory/usage), converted to GB.",
      "fieldConfig": {"defaults": {"unit": "decgbytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
          "expr": "stackdriver_tpu_worker_tpu_googleapis_com_tpu_memory_usage{project_id=~\"$project_id\",node_id=~\"$tpu_name\",zone=~\"$zone\"} / 1e9",
          "legendFormat": "HBM used {{node_id}}/{{tpu_worker_id}}",
          "refId": "A"
        }
      ],
      "title": "HBM Used (GB)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
      "description": "HBM utilization = memory_usage / memory_total. Anything > 90% sustained is a red flag.",
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
          "expr": "(stackdriver_tpu_worker_tpu_googleapis_com_tpu_memory_usage{project_id=~\"$project_id\",node_id=~\"$tpu_name\",zone=~\"$zone\"} / stackdriver_tpu_worker_tpu_googleapis_com_tpu_memory_total{project_id=~\"$project_id\",node_id=~\"$tpu_name\",zone=~\"$zone\"}) * 100",
          "legendFormat": "HBM util {{node_id}}/{{tpu_worker_id}}",
          "refId": "A"
        }
      ],
      "title": "HBM Utilization (%)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
      "description": "TensorCore idle duration in seconds (tpu.googleapis.com/tpu/tensorcore/idle_duration). Lower is better — high idle implies pipeline bubbles or input-bound steps.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "cloud_tpu_lab_prometheus"},
          "expr": "stackdriver_tpu_worker_tpu_googleapis_com_tpu_tensorcore_idle_duration{project_id=~\"$project_id\",node_id=~\"$tpu_name\",zone=~\"$zone\"}",
