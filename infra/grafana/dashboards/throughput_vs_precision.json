{
  "uid": "tpu-bench-throughput",
  "title": "TPU Bench - Throughput vs Precision",
  "tags": ["tpu-bench"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "",
  "templating": {
    "list": [
      {
        "name": "model_id",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(benchmark_throughput_samples_sec_count, model_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Mean throughput by precision x device (samples/sec)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg by (precision, device) (rate(benchmark_throughput_samples_sec_sum{model_id=~\"$model_id\"}[$__rate_interval]) / clamp_min(rate(benchmark_throughput_samples_sec_count{model_id=~\"$model_id\"}[$__rate_interval]), 1e-9))",
          "legendFormat": "{{precision}} / {{device}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "axisPlacement": "auto",
            "axisLabel": "samples/sec"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Model x device x precision summary",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg by (model_id, device, precision) (rate(benchmark_throughput_samples_sec_sum{model_id=~\"$model_id\"}[$__rate_interval]) / clamp_min(rate(benchmark_throughput_samples_sec_count{model_id=~\"$model_id\"}[$__rate_interval]), 1e-9))",
          "legendFormat": "throughput",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg by (model_id, device, precision) (benchmark_compile_cold_seconds_sum{model_id=~\"$model_id\"} / clamp_min(benchmark_compile_cold_seconds_count{model_id=~\"$model_id\"}, 1))",
          "legendFormat": "compile_cold_s",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg by (model_id, device, precision) (benchmark_compile_warm_seconds_sum{model_id=~\"$model_id\"} / clamp_min(benchmark_compile_warm_seconds_count{model_id=~\"$model_id\"}, 1))",
          "legendFormat": "compile_warm_s",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "Value #A": "mean_throughput",
              "Value #B": "mean_compile_cold_s",
              "Value #C": "mean_compile_warm_s"
            },
            "indexByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "mean_throughput"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mean_compile_cold_s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "mean_compile_warm_s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    }
  ],
  "annotations": {
    "list": []
  }
}
