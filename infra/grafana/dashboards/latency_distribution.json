{
  "uid": "tpu-bench-latency",
  "title": "TPU Bench - Latency Distribution",
  "tags": ["tpu-bench"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "",
  "templating": {
    "list": [
      {
        "name": "model_id",
        "label": "Model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(benchmark_latency_ms_bucket, model_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "device",
        "label": "Device",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(benchmark_latency_ms_bucket{model_id=~\"$model_id\"}, device)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "precision",
        "label": "Precision",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(benchmark_latency_ms_bucket{model_id=~\"$model_id\",device=~\"$device\"}, precision)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "heatmap",
      "title": "Latency heatmap (benchmark.latency.ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (le) (rate(benchmark_latency_ms_bucket{model_id=~\"$model_id\",device=~\"$device\",precision=~\"$precision\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "unit": "ms"
        },
        "color": {
          "scheme": "Spectral",
          "mode": "scheme"
        },
        "cellGap": 1,
        "legend": {
          "show": true
        },
        "tooltip": {
          "show": true,
          "yHistogram": true
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p50 / p95 / p99 latency (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(benchmark_latency_ms_bucket{model_id=~\"$model_id\",device=~\"$device\",precision=~\"$precision\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(benchmark_latency_ms_bucket{model_id=~\"$model_id\",device=~\"$device\",precision=~\"$precision\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(benchmark_latency_ms_bucket{model_id=~\"$model_id\",device=~\"$device\",precision=~\"$precision\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Current p95 per model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le, model_id) (rate(benchmark_latency_ms_bucket{model_id=~\"$model_id\",device=~\"$device\",precision=~\"$precision\"}[5m])))",
          "legendFormat": "{{model_id}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    }
  ],
  "annotations": {
    "list": []
  }
}
